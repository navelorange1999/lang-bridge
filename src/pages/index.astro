---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCodeBlock from '../components/HeroCodeBlock.astro';
import LanguagePills from '../components/LanguagePills.astro';

const helloWorld: Record<string, { label: string; code: string }> = {
  cpp:        { label: 'C++',        code: 'std::cout << "Hello, World!" << std::endl;' },
  python:     { label: 'Python',     code: 'print("Hello, World!")' },
  typescript: { label: 'TypeScript', code: 'console.log("Hello, World!");' },
  go:         { label: 'Go',         code: 'fmt.Println("Hello, World!")' },
  rust:       { label: 'Rust',       code: 'println!("Hello, World!");' },
  java:       { label: 'Java',       code: 'System.out.println("Hello, World!");' },
};

const defaultLang = 'cpp';
const languages = Object.entries(helloWorld).map(([id, { label }]) => ({ id, label }));
---

<BaseLayout
  title="LangBridge"
  description="Learn programming languages by comparing syntax side-by-side."
>
  <section class="max-w-[1400px] w-[calc(100%-2rem)] mx-auto">
    <div class="min-h-[calc(100vh-4rem)] py-20 md:py-32 flex flex-col items-center justify-center text-center">

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground">
        Learn by comparing.
      </h1>

      <p class="mt-4 text-base md:text-lg text-muted-foreground max-w-xl">
        Side-by-side syntax comparison across 6 programming languages.
        See how the same concept looks in TypeScript, Python, Go, Rust, C++, and Java.
      </p>

      <div class="mt-12 w-full max-w-2xl">
        <HeroCodeBlock defaultCode={helloWorld[defaultLang].code} defaultLanguage={helloWorld[defaultLang].label} />
      </div>

      <div class="mt-6">
        <LanguagePills languages={languages} activeLanguage={defaultLang} />
      </div>

      <a
        href="/diff"
        class="mt-12 inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary text-primary-foreground font-medium text-base hover:opacity-90 transition-opacity"
      >
        Start Comparing
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>

    </div>
  </section>

  <script>
    const HELLO_WORLD: Record<string, { label: string; code: string; html: string }> = {
      cpp: {
        label: 'C++',
        code: 'std::cout << "Hello, World!" << std::endl;',
        html: '<span class="hl-ns">std</span><span class="hl-op">::</span><span class="hl-fn">cout</span> <span class="hl-op">&lt;&lt;</span> <span class="hl-str">"Hello, World!"</span> <span class="hl-op">&lt;&lt;</span> <span class="hl-ns">std</span><span class="hl-op">::</span><span class="hl-fn">endl</span>;',
      },
      python: {
        label: 'Python',
        code: 'print("Hello, World!")',
        html: '<span class="hl-fn">print</span>(<span class="hl-str">"Hello, World!"</span>)',
      },
      typescript: {
        label: 'TypeScript',
        code: 'console.log("Hello, World!");',
        html: '<span class="hl-ns">console</span>.<span class="hl-fn">log</span>(<span class="hl-str">"Hello, World!"</span>);',
      },
      go: {
        label: 'Go',
        code: 'fmt.Println("Hello, World!")',
        html: '<span class="hl-ns">fmt</span>.<span class="hl-fn">Println</span>(<span class="hl-str">"Hello, World!"</span>)',
      },
      rust: {
        label: 'Rust',
        code: 'println!("Hello, World!");',
        html: '<span class="hl-fn">println!</span>(<span class="hl-str">"Hello, World!"</span>);',
      },
      java: {
        label: 'Java',
        code: 'System.out.println("Hello, World!");',
        html: '<span class="hl-ns">System</span>.out.<span class="hl-fn">println</span>(<span class="hl-str">"Hello, World!"</span>);',
      },
    };

    let currentTyped: any = null;
    let currentLang = 'cpp';
    let backspaceTimer: number | null = null;

    async function loadTypedJs() {
      const module = await import('https://cdn.jsdelivr.net/npm/typed.js@2.1.0/+esm');
      return module.default;
    }

    function applyHighlight(el: HTMLElement, lang: string) {
      // Remove Typed.js cursor temporarily, apply highlighted HTML, then re-add cursor
      const cursor = el.parentElement?.querySelector('.typed-cursor');
      el.innerHTML = HELLO_WORLD[lang].html;
      if (cursor) el.after(cursor);
    }

    async function initHero() {
      const Typed = await loadTypedJs();
      const typedEl = document.getElementById('hero-typed');
      const labelEl = document.getElementById('hero-lang-label');
      const pillContainer = document.getElementById('lang-pills');
      if (!typedEl || !labelEl || !pillContainer) return;

      // Clear server-rendered text before Typed.js takes over
      typedEl.textContent = '';

      // Initial type-in animation
      currentTyped = new Typed(typedEl, {
        strings: [HELLO_WORLD[currentLang].code],
        typeSpeed: 40,
        showCursor: true,
        cursorChar: '|',
        onComplete: () => applyHighlight(typedEl, currentLang),
      });

      // Pill click handler
      pillContainer.addEventListener('click', (e: Event) => {
        const btn = (e.target as HTMLElement).closest('[data-lang]') as HTMLElement | null;
        if (!btn) return;
        const lang = btn.dataset.lang;
        if (!lang || lang === currentLang) return;

        // Cancel any in-progress animation
        if (backspaceTimer !== null) {
          clearTimeout(backspaceTimer);
          backspaceTimer = null;
        }
        if (currentTyped) {
          currentTyped.destroy();
          currentTyped = null;
        }

        // Update active pill styling
        pillContainer.querySelectorAll('[data-lang]').forEach((pill) => {
          const isActive = pill.getAttribute('data-lang') === lang;
          pill.classList.toggle('bg-primary', isActive);
          pill.classList.toggle('text-primary-foreground', isActive);
          pill.classList.toggle('bg-muted', !isActive);
          pill.classList.toggle('text-muted-foreground', !isActive);
        });

        // Backspace old text, then type new text
        const oldText = HELLO_WORLD[currentLang].code;
        const newText = HELLO_WORLD[lang].code;
        let charIndex = oldText.length;

        typedEl.textContent = oldText;
        typedEl.classList.add('backspacing');

        function backspace() {
          if (charIndex > 0) {
            charIndex--;
            typedEl!.textContent = oldText.substring(0, charIndex);
            backspaceTimer = window.setTimeout(backspace, 20);
          } else {
            backspaceTimer = null;
            typedEl!.classList.remove('backspacing');
            labelEl!.textContent = HELLO_WORLD[lang!].label.toLowerCase();

            currentTyped = new Typed(typedEl!, {
              strings: [newText],
              typeSpeed: 40,
              startDelay: 150,
              showCursor: true,
              cursorChar: '|',
              onComplete: () => applyHighlight(typedEl!, lang!),
            });
          }
        }

        currentLang = lang;
        backspace();
      });
    }

    initHero();
  </script>
</BaseLayout>
