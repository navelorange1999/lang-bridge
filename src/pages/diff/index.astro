---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import LanguageSelector from '../../components/LanguageSelector.astro';
import ConceptBlock from '../../components/ConceptBlock.astro';
import { languageDisplayName } from '../../utils/strings';

// Get all concept entries (each is {category}/{concept}/{language})
const allEntries = await getCollection('concepts');

// Group entries into concepts
interface ConceptData {
  id: string;
  title: string;
  category: string;
  order: number;
  languages: Record<string, { sections: Array<{ id: string; code: string }>; explanation: string }>;
}

const conceptMap = new Map<string, ConceptData>();
const languageSet = new Set<string>();

for (const entry of allEntries) {
  const parts = entry.id.split('/');
  const category = parts[0];
  const conceptId = parts[1];
  const language = parts[2];

  languageSet.add(language);

  if (!conceptMap.has(conceptId)) {
    conceptMap.set(conceptId, {
      id: conceptId,
      title: entry.data.title,
      category,
      order: entry.data.order,
      languages: {},
    });
  }
  conceptMap.get(conceptId)!.languages[language] = {
    sections: entry.data.sections,
    explanation: entry.data.explanation,
  };
}

const allConcepts = Array.from(conceptMap.values()).sort((a, b) => a.order - b.order);
const availableLanguages = Array.from(languageSet).sort();

// Default languages for initial server render
const defaultFrom = 'typescript';
const defaultTo = 'python';
---

<BaseLayout
  title={`LangBridge — ${languageDisplayName(defaultFrom)} → ${languageDisplayName(defaultTo)}`}
  description={`Learn programming languages with side-by-side syntax comparisons.`}
  brandUrl="/"
>
  <div class="max-w-[1400px] w-[calc(100%-2rem)] mx-auto flex min-h-[calc(100vh-var(--navbar-height))]">
    <Sidebar concepts={allConcepts.map(c => ({ id: c.id, data: { title: c.title, category: c.category, order: c.order } }))} />

    <!-- Main content -->
    <main class="flex-1 min-w-0">
      <!-- Sticky toolbar — extends right to viewport edge -->
      <div class="sticky top-[var(--navbar-height)] z-40 bg-background border-b border-border -mr-[max((100vw-1400px)/2,1rem)] pr-[max((100vw-1400px)/2,1rem)] -ml-4 pl-4 md:ml-0 md:pl-0">
        <div class="py-2.5 pl-3 pr-3 flex items-center justify-between">
          <LanguageSelector fromLang={defaultFrom} toLang={defaultTo} availableLanguages={availableLanguages} />
          <button
            id="theme-toggle"
            type="button"
            class="p-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
            aria-label="Toggle dark mode"
          >
            <svg class="theme-icon-sun w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
            </svg>
            <svg class="theme-icon-moon w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
            </svg>
          </button>
        </div>
      </div>

      <div class="py-4 md:py-8 pl-3 md:pr-0 pr-3">
        <p class="md:hidden text-xs text-muted-foreground mb-2">Long press code to compare</p>
        {allConcepts.map((concept, i) => (
          <div class="concept-panel" data-concept={concept.id} style={i === 0 ? '' : 'display:none'}>
            <ConceptBlock
              title={concept.title}
              fromLang={defaultFrom}
              toLang={defaultTo}
              languages={concept.languages}
            />
          </div>
        ))}
      </div>
    </main>
  </div>

  {/* Mobile bottom sheet for comparing "from" language */}
  <div id="code-bottom-sheet" class="md:hidden fixed inset-0 z-[70] pointer-events-none" style="display:none">
    <div id="code-sheet-overlay" class="absolute inset-0 bg-black/40 opacity-0 transition-opacity duration-300 pointer-events-none"></div>
    <div id="code-sheet-panel"
         class="absolute left-0 right-0 max-h-[60vh] overflow-y-auto transition-transform duration-300 pointer-events-auto"
         style="background-color: #24292e;">
      <div class="flex items-center justify-between px-2 pt-3 pb-2">
        <span id="code-sheet-label" class="text-xs uppercase tracking-widest font-medium" style="color: #8b949e;"></span>
        <button id="code-sheet-close" type="button" class="p-1" style="color: #8b949e;" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="code-sheet-content" class="px-2 pb-4"></div>
    </div>
  </div>

  <script>
    function initApp() {
      const nav = document.getElementById('concept-nav');
      const mobileNav = document.getElementById('concept-nav-mobile');
      const fromSelect = document.getElementById('lang-from') as HTMLSelectElement | null;
      const toSelect = document.getElementById('lang-to') as HTMLSelectElement | null;
      if (!nav || !fromSelect || !toSelect) return;

      const ACTIVE = 'bg-muted text-primary';
      const INACTIVE = 'text-muted-foreground hover:text-foreground hover:bg-muted';

      // --- Language switching ---
      function disableSameLanguageOptions() {
        const fromVal = fromSelect!.value;
        const toVal = toSelect!.value;
        for (const opt of fromSelect!.options) {
          opt.disabled = opt.value === toVal;
        }
        for (const opt of toSelect!.options) {
          opt.disabled = opt.value === fromVal;
        }
      }

      function switchLanguages(fromLang: string, toLang: string) {
        document.querySelectorAll<HTMLElement>('.code-section[data-side="from"]').forEach((el) => {
          el.style.display = el.dataset.lang === fromLang ? '' : 'none';
        });
        document.querySelectorAll<HTMLElement>('.code-section[data-side="to"]').forEach((el) => {
          el.style.display = el.dataset.lang === toLang ? '' : 'none';
        });
        document.querySelectorAll<HTMLElement>('.lang-label[data-side="from"]').forEach((el) => {
          el.textContent = fromLang;
        });
        document.querySelectorAll<HTMLElement>('.lang-label[data-side="to"]').forEach((el) => {
          el.textContent = toLang;
        });
        disableSameLanguageOptions();
      }

      function updateUrlAndSwitch() {
        const fromLang = fromSelect!.value;
        const toLang = toSelect!.value;
        switchLanguages(fromLang, toLang);
        const url = new URL(location.href);
        url.searchParams.set('from', fromLang);
        url.searchParams.set('to', toLang);
        history.replaceState(null, '', url.toString());
      }

      fromSelect.addEventListener('change', updateUrlAndSwitch);
      toSelect.addEventListener('change', updateUrlAndSwitch);

      const params = new URLSearchParams(location.search);
      const urlFrom = params.get('from');
      const urlTo = params.get('to');
      if (urlFrom && fromSelect.querySelector(`option[value="${urlFrom}"]`)) {
        fromSelect.value = urlFrom;
      }
      if (urlTo && toSelect.querySelector(`option[value="${urlTo}"]`)) {
        toSelect.value = urlTo;
      }
      if (fromSelect.value === toSelect.value) {
        fromSelect.value = 'typescript';
        toSelect.value = 'python';
      }
      switchLanguages(fromSelect.value, toSelect.value);

      // --- Concept navigation ---
      function switchConcept(id: string) {
        document.querySelectorAll('.concept-panel').forEach((el) => {
          (el as HTMLElement).style.display = el.getAttribute('data-concept') === id ? '' : 'none';
        });
        // Update active state in ALL navs (desktop + mobile)
        document.querySelectorAll('.concept-link').forEach((link) => {
          const isActive = link.getAttribute('data-concept') === id;
          ACTIVE.split(' ').forEach((c) => link.classList.toggle(c, isActive));
          INACTIVE.split(' ').forEach((c) => link.classList.toggle(c, !isActive));
        });
      }

      const initialConcept = params.get('concept');
      if (initialConcept && document.querySelector(`.concept-panel[data-concept="${initialConcept}"]`)) {
        switchConcept(initialConcept);
      }

      function handleNavClick(e: Event) {
        const link = (e.target as HTMLElement).closest('.concept-link');
        if (!link) return;
        e.preventDefault();
        const id = link.getAttribute('data-concept');
        if (!id) return;
        switchConcept(id);
        const url = new URL(location.href);
        url.searchParams.set('concept', id);
        history.pushState(null, '', url.toString());
      }

      nav.addEventListener('click', handleNavClick);
      mobileNav?.addEventListener('click', handleNavClick);

      window.addEventListener('popstate', () => {
        const p = new URLSearchParams(location.search);
        const id = p.get('concept');
        if (id) switchConcept(id);
        const pFrom = p.get('from');
        const pTo = p.get('to');
        if (pFrom && fromSelect.querySelector(`option[value="${pFrom}"]`)) {
          fromSelect.value = pFrom;
        }
        if (pTo && toSelect.querySelector(`option[value="${pTo}"]`)) {
          toSelect.value = pTo;
        }
        switchLanguages(fromSelect.value, toSelect.value);
      });
    }

    initApp();

    // --- Mobile: bottom sheet for long-press code comparison ---
    function initMobileCodeSheet() {
      const sheet = document.getElementById('code-bottom-sheet');
      const panel = document.getElementById('code-sheet-panel');
      const overlay = document.getElementById('code-sheet-overlay');
      const content = document.getElementById('code-sheet-content');
      const label = document.getElementById('code-sheet-label');
      const closeBtn = document.getElementById('code-sheet-close');
      if (!sheet || !panel || !overlay || !content || !label || !closeBtn) return;

      let longPressTimer: number | null = null;
      let sheetPosition: 'bottom' | 'top' = 'bottom';

      function openSheet(fromTop: boolean) {
        sheetPosition = fromTop ? 'top' : 'bottom';

        // Position the panel
        if (fromTop) {
          panel.style.top = '0';
          panel.style.bottom = '';
          panel.classList.add('rounded-b-xl');
          panel.classList.remove('rounded-t-xl');
          panel.style.transform = 'translateY(-100%)';
        } else {
          panel.style.top = '';
          panel.style.bottom = '0';
          panel.classList.add('rounded-t-xl');
          panel.classList.remove('rounded-b-xl');
          panel.style.transform = 'translateY(100%)';
        }

        sheet.style.display = '';
        void panel.offsetHeight;
        overlay.classList.add('opacity-100');
        overlay.classList.remove('pointer-events-none');
        panel.style.transform = 'translateY(0)';
      }

      function closeSheet() {
        overlay.classList.remove('opacity-100');
        overlay.classList.add('pointer-events-none');
        panel.style.transform = sheetPosition === 'top' ? 'translateY(-100%)' : 'translateY(100%)';
        setTimeout(() => { sheet.style.display = 'none'; }, 300);
      }

      overlay.addEventListener('click', closeSheet);
      closeBtn.addEventListener('click', closeSheet);

      // Bind long-press on all to-side section cells (touch + mouse for desktop small screens)
      document.querySelectorAll<HTMLElement>('.section-cell[data-side="to"]').forEach(cell => {
        let pressY = 0;

        function triggerSheet(clientY: number) {
          longPressTimer = window.setTimeout(() => {
            longPressTimer = null;
            const visibleSection = cell.querySelector('.code-section:not([style*="display:none"]):not([style*="display: none"])') as HTMLElement | null;
            if (!visibleSection) return;
            const sectionId = visibleSection.getAttribute('data-section');
            const fromLang = (document.getElementById('lang-from') as HTMLSelectElement)?.value;
            if (!sectionId || !fromLang) return;

            const conceptPanel = cell.closest('.concept-panel');
            const fromSection = conceptPanel?.querySelector(
              `.code-section[data-side="from"][data-lang="${fromLang}"][data-section="${sectionId}"]`
            ) as HTMLElement | null;
            if (!fromSection) return;

            label.textContent = fromLang;
            content.innerHTML = fromSection.innerHTML;

            const fromTop = clientY > window.innerHeight / 2;
            openSheet(fromTop);
          }, 500);
        }

        function cancelPress() {
          if (longPressTimer !== null) {
            clearTimeout(longPressTimer);
            longPressTimer = null;
          }
        }

        // Touch events
        cell.addEventListener('touchstart', (e: TouchEvent) => {
          pressY = e.touches[0].clientY;
          triggerSheet(pressY);
        }, { passive: true });
        cell.addEventListener('touchend', cancelPress);
        cell.addEventListener('touchmove', cancelPress);

        // Mouse events (for desktop narrow viewports)
        cell.addEventListener('mousedown', (e: MouseEvent) => {
          pressY = e.clientY;
          triggerSheet(pressY);
        });
        cell.addEventListener('mouseup', cancelPress);
        cell.addEventListener('mouseleave', cancelPress);
      });
    }

    initMobileCodeSheet();

    function initThemeToggle() {
      const btn = document.getElementById('theme-toggle');
      if (!btn) return;

      const sunIcon = btn.querySelector('.theme-icon-sun') as HTMLElement;
      const moonIcon = btn.querySelector('.theme-icon-moon') as HTMLElement;

      function updateIcons() {
        const isDark = document.documentElement.classList.contains('dark');
        sunIcon.style.display = isDark ? 'block' : 'none';
        moonIcon.style.display = isDark ? 'none' : 'block';
      }

      btn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateIcons();
      });

      updateIcons();
    }

    initThemeToggle();
  </script>
</BaseLayout>
