---
import { capitalize } from '../utils/strings';

interface Props {
  fromLang: string;
  toLang: string;
  availableLanguages: string[];
}

const { fromLang, toLang, availableLanguages } = Astro.props;
---

<div id="lang-form" class="flex items-center gap-3 text-sm">
  <select
    id="lang-from"
    class="bg-muted text-foreground font-medium px-3 py-1.5 rounded-md border border-border cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary"
  >
    {availableLanguages.map((lang) => (
      <option value={lang} selected={lang === fromLang}>{capitalize(lang)}</option>
    ))}
  </select>

  <span class="text-muted-foreground select-none">→</span>

  <select
    id="lang-to"
    class="bg-muted text-foreground font-medium px-3 py-1.5 rounded-md border border-border cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary"
  >
    {availableLanguages.map((lang) => (
      <option value={lang} selected={lang === toLang}>{capitalize(lang)}</option>
    ))}
  </select>
</div>
