---
interface Props {
  defaultCode: string;
  defaultLanguage: string;
}

const { defaultCode, defaultLanguage } = Astro.props;
---

<div class="bg-gray-950 rounded-lg overflow-hidden">
  <div class="flex items-center justify-between px-4 pt-3 pb-0">
    <span id="hero-lang-label" class="text-xs uppercase tracking-widest font-medium" style="color: #8b949e;">
      {defaultLanguage.toLowerCase()}
    </span>
    <div class="flex gap-1.5">
      <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
      <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
      <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
    </div>
  </div>
  <div class="px-4 py-5 overflow-x-auto">
    <pre class="font-mono text-base md:text-lg leading-relaxed" style="color: #e1e4e8; margin: 0;"><span id="hero-typed">{defaultCode}</span></pre>
  </div>
</div>

<style>
  #hero-typed.backspacing::after {
    content: '|';
    color: var(--primary);
    animation: blink 0.7s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>

<style is:global>
  .typed-cursor {
    color: var(--primary);
    font-weight: 100;
  }

  .hl-fn { color: #b392f0; }
  .hl-str { color: #9ecbff; }
  .hl-op { color: #f97583; }
  .hl-ns { color: #79b8ff; }
</style>
