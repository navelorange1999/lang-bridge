---
interface Props {
  languages: { id: string; label: string }[];
  activeLanguage: string;
}

const { languages, activeLanguage } = Astro.props;
---

<div id="lang-pills" class="flex flex-wrap gap-2 justify-center">
  {languages.map(({ id, label }) => (
    <button
      data-lang={id}
      class:list={[
        'px-3 py-1 md:px-4 md:py-1.5 rounded-full text-xs md:text-sm font-medium transition-colors cursor-pointer',
        id === activeLanguage
          ? 'bg-primary text-primary-foreground'
          : 'bg-muted text-muted-foreground hover:text-foreground',
      ]}
    >
      {label}
    </button>
  ))}
</div>
