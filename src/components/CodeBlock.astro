---
interface Props {
  code: string;
  language: string;
}

const { code, language } = Astro.props;
---

<div class="relative">
  <div class="absolute top-2 right-2 text-xs text-gray-400 uppercase font-mono">{language}</div>
  <pre class="bg-gray-900 text-gray-100 rounded-lg p-4 pt-8 overflow-x-auto text-sm font-mono leading-relaxed"><code>{code.trim()}</code></pre>
</div>
