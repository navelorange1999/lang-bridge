---
import { Code } from 'astro:components';

interface Props {
  code: string;
  language: string;
}

const { code, language } = Astro.props;
---

<div class="flex flex-col h-full">
  <span class="text-xs uppercase tracking-widest text-muted-foreground font-medium">{language}</span>
  <div class="mt-2 flex-1 rounded-lg overflow-hidden [&_pre]:!rounded-lg [&_pre]:!p-4 [&_pre]:!text-sm [&_pre]:!leading-relaxed [&_pre]:!h-full">
    <Code code={code.trim()} lang={language} theme="github-dark" />
  </div>
</div>
