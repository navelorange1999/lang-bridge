---
import { Code } from 'astro:components';
import { capitalize } from '../utils/strings';

interface Section {
  id: string;
  code: string;
  lang?: string;
}

interface LanguageEntry {
  sections: Section[];
  explanation: string;
}

interface Props {
  title: string;
  fromLang: string;
  toLang: string;
  languages: Record<string, LanguageEntry>;
}

const { title, fromLang, toLang, languages } = Astro.props;

const langEntries = Object.entries(languages).sort(([a], [b]) => a.localeCompare(b));

// Build section lookup: sectionId → lang → Section
const sectionIds = langEntries[0][1].sections.map(s => s.id);
const sectionMap = new Map<string, Map<string, Section>>();
for (const [lang, entry] of langEntries) {
  for (const section of entry.sections) {
    if (!sectionMap.has(section.id)) sectionMap.set(section.id, new Map());
    sectionMap.get(section.id)!.set(lang, section);
  }
}
---

<article>
  <h1 class="text-2xl font-bold text-foreground">{title}</h1>

  <!-- Side-by-side code comparison: row-based for alignment -->
  <div class="comparison-grid mt-6">
    <!-- Header row -->
    <span class="lang-label text-xs uppercase tracking-widest text-muted-foreground font-medium" data-side="from">{fromLang}</span>
    <span class="lang-label text-xs uppercase tracking-widest text-muted-foreground font-medium" data-side="to">{toLang}</span>

    <!-- Section rows -->
    {sectionIds.map((sectionId, i) => {
      const isFirst = i === 0;
      const isLast = i === sectionIds.length - 1;
      const cellClass = `section-cell${isFirst ? ' first' : ''}${isLast ? ' last' : ''}`;
      return (
        <>
          <div class={cellClass}>
            {langEntries.map(([lang]) => {
              const section = sectionMap.get(sectionId)?.get(lang);
              return section && (
                <div class="code-section" data-side="from" data-lang={lang} data-section={sectionId}
                     style={lang === fromLang ? '' : 'display:none'}>
                  <Code code={section.code.trim()} lang={section.lang || lang} theme="github-dark" />
                </div>
              );
            })}
          </div>
          <div class={cellClass}>
            {langEntries.map(([lang]) => {
              const section = sectionMap.get(sectionId)?.get(lang);
              return section && (
                <div class="code-section" data-side="to" data-lang={lang} data-section={sectionId}
                     style={lang === toLang ? '' : 'display:none'}>
                  <Code code={section.code.trim()} lang={section.lang || lang} theme="github-dark" />
                </div>
              );
            })}
          </div>
        </>
      );
    })}
  </div>

</article>

<style>
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 1.25rem;
  }

  .section-cell {
    background-color: #24292e;
    overflow: hidden;
  }

  .section-cell.first {
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
    margin-top: 0.5rem;
  }

  .section-cell.last {
    border-bottom-left-radius: 0.5rem;
    border-bottom-right-radius: 0.5rem;
  }

  .code-section {
    transition: background-color 0.2s ease, opacity 0.2s ease;
    cursor: default;
  }

  .code-section :global(pre) {
    background: transparent !important;
    border-radius: 0 !important;
    margin: 0 !important;
    padding: 0 1rem !important;
    font-size: 0.875rem !important;
    line-height: 1.625 !important;
  }

  /* Top padding for first section row */
  .section-cell.first .code-section :global(pre) {
    padding-top: 1rem !important;
  }

  /* Bottom padding for last section row */
  .section-cell.last .code-section :global(pre) {
    padding-bottom: 1rem !important;
  }

  /* Blank line gap between consecutive section rows */
  .section-cell:not(.first) .code-section :global(pre) {
    padding-top: 1.625em !important;
  }

  /* Hover: highlight active section */
  .code-section.highlighted {
    background-color: rgba(136, 198, 255, 0.1);
  }

  /* Hover: dim non-active sections */
  .comparison-grid:has(.highlighted) .code-section:not(.highlighted) {
    opacity: 0.4;
  }

  /* Responsive: single column on mobile */
  @media (max-width: 768px) {
    .comparison-grid {
      grid-template-columns: 1fr;
    }
    .code-section[data-side="to"] {
      display: none !important;
    }
    .lang-label[data-side="to"] {
      display: none;
    }
  }
</style>

<script>
  function initCodeHover() {
    const sections = document.querySelectorAll<HTMLElement>('.code-section');

    sections.forEach(section => {
      section.addEventListener('mouseenter', () => {
        const idx = section.dataset.section;
        document.querySelectorAll<HTMLElement>(`.code-section[data-section="${idx}"]`).forEach(s => {
          s.classList.add('highlighted');
        });
      });

      section.addEventListener('mouseleave', () => {
        document.querySelectorAll('.code-section.highlighted').forEach(s => {
          s.classList.remove('highlighted');
        });
      });
    });
  }

  // Support both initial load and Astro view transitions
  initCodeHover();
  document.addEventListener('astro:after-swap', initCodeHover);
</script>
