---
interface ConceptEntry {
  id: string;
  data: { title: string; category: string; order: number };
}

interface Props {
  concepts: ConceptEntry[];
}

const CATEGORY_LABELS: Record<string, string> = {
  'basics': 'Basics',
  'control-flow': 'Control Flow',
  'functions-org': 'Functions & Organization',
  'data-structures': 'Data Structures',
  'types-objects': 'Types & Objects',
  'error-handling': 'Error Handling',
  'advanced': 'Advanced',
};

const { concepts } = Astro.props;

// Group by category (concepts are already sorted by order from the parent)
const grouped: { label: string; concepts: ConceptEntry[] }[] = [];
let currentCategory = '';
for (const concept of concepts) {
  if (concept.data.category !== currentCategory) {
    currentCategory = concept.data.category;
    grouped.push({
      label: CATEGORY_LABELS[currentCategory] || currentCategory,
      concepts: [],
    });
  }
  grouped[grouped.length - 1].concepts.push(concept);
}
---

{/* Desktop sidebar */}
<aside class="hidden md:block w-48 shrink-0 border-r border-border">
  <nav id="concept-nav" class="sticky top-[var(--navbar-height)] pt-4 pb-6 px-2 max-h-[calc(100vh-var(--navbar-height))] overflow-y-auto">
    {grouped.map((group, gi) => (
      <div class:list={[gi > 0 && 'mt-3']}>
        <span class="block px-2 pt-1 pb-1.5 text-[13px] font-semibold text-foreground select-none">
          {group.label}
        </span>
        {group.concepts.map((concept, i) => (
          <a
            href="#"
            data-concept={concept.id}
            class:list={[
              'concept-link block px-2 py-1.5 rounded-md text-[13px] transition-colors',
              gi === 0 && i === 0
                ? 'bg-muted text-primary font-medium'
                : 'text-muted-foreground hover:text-foreground hover:bg-muted',
            ]}
          >
            {concept.data.title}
          </a>
        ))}
      </div>
    ))}
  </nav>
</aside>

{/* Mobile: FAB + Right Drawer */}
<button
  id="sidebar-fab"
  type="button"
  class="md:hidden fixed bottom-6 right-4 z-50 w-12 h-12 rounded-full bg-primary text-primary-foreground shadow-lg flex items-center justify-center"
  aria-label="Open navigation"
>
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
  </svg>
</button>

<div id="sidebar-drawer" class="md:hidden fixed inset-0 z-[60] pointer-events-none" style="display:none">
  <div id="sidebar-overlay" class="absolute inset-0 bg-black/40 opacity-0 transition-opacity duration-300"></div>
  <nav
    id="concept-nav-mobile"
    class="absolute right-0 top-0 h-full w-64 bg-background border-l border-border translate-x-full transition-transform duration-300 overflow-y-auto pointer-events-auto pt-4 pb-6 px-2"
  >
    {grouped.map((group, gi) => (
      <div class:list={[gi > 0 && 'mt-3']}>
        <span class="block px-2 pt-1 pb-1.5 text-[13px] font-semibold text-foreground select-none">
          {group.label}
        </span>
        {group.concepts.map((concept, i) => (
          <a
            href="#"
            data-concept={concept.id}
            class:list={[
              'concept-link block px-2 py-1.5 rounded-md text-[13px] transition-colors',
              gi === 0 && i === 0
                ? 'bg-muted text-primary font-medium'
                : 'text-muted-foreground hover:text-foreground hover:bg-muted',
            ]}
          >
            {concept.data.title}
          </a>
        ))}
      </div>
    ))}
  </nav>
</div>

<script>
  function initSidebarDrawer() {
    const fab = document.getElementById('sidebar-fab');
    const drawer = document.getElementById('sidebar-drawer');
    const overlay = document.getElementById('sidebar-overlay');
    const panel = document.getElementById('concept-nav-mobile');
    if (!fab || !drawer || !overlay || !panel) return;

    function open() {
      drawer.style.display = '';
      drawer.style.pointerEvents = 'auto';
      void panel.offsetHeight;
      overlay.classList.add('opacity-100');
      panel.classList.remove('translate-x-full');
      panel.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      overlay.classList.remove('opacity-100');
      panel.classList.remove('translate-x-0');
      panel.classList.add('translate-x-full');
      document.body.style.overflow = '';
      setTimeout(() => {
        drawer.style.display = 'none';
        drawer.style.pointerEvents = '';
      }, 300);
    }

    fab.addEventListener('click', open);
    overlay.addEventListener('click', close);

    // Close drawer when a concept link is clicked
    panel.addEventListener('click', (e: Event) => {
      const link = (e.target as HTMLElement).closest('.concept-link');
      if (link) close();
    });
  }

  initSidebarDrawer();
</script>
